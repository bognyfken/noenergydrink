{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "rewrites": [{ "source": "/((?!assets/|icons/|api/|.*\\..*).*)", "destination": "/index.html" }],
  "crons": [{ "path": "/api/cron-reminders", "schedule": "0 17 * * *" }]
}
