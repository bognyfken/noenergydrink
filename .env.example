# Скопируй в .env и заполни. Файл .env в .gitignore — в git не попадёт.

# ── Supabase (облачная синхронизация) ────────────────────────────────────
# Создай проект на https://supabase.com → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Идентификатор единственного пользователя (любая строка, напр. имя)
VITE_APP_USER_ID=default

# ── Cerebras / Qwen (ИИ-помощник, ЭТАП 3 — пока не нужно) ─────────────────
# Ключ хранится на сервере (Vercel env), НЕ здесь с префиксом VITE_.
# CEREBRAS_API_KEY=
