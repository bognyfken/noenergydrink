# Скопируй в .env и заполни. Файл .env в .gitignore — в git не попадёт.

# ── Supabase (облачная синхронизация) ────────────────────────────────────
# Создай проект на https://supabase.com → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Идентификатор единственного пользователя (любая строка, напр. имя)
VITE_APP_USER_ID=default

# ── Cerebras / Qwen (ИИ-помощник «Кабанёнок») ────────────────────────────
# Ключ читается ТОЛЬКО серверным прокси api/chat.ts (без префикса VITE_, не в бандл).
# Задать в Vercel → Project → Settings → Environment Variables, и здесь для
# локального `vercel dev`. Модель: qwen-3-235b-a22b-instruct.
CEREBRAS_API_KEY=
